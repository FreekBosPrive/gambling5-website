{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run Gambling5.Web",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Gambling5.Web/Gambling5.Web.csproj",
        "--urls",
        "http://localhost:5259"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Now listening on: http://localhost:5259"
        }
      }
    }
  ]
}
