@implements IDisposable
@inject Gambling5.Web.Services.LanguageService L

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <p role="alert">@L.T("Sie haben keine Berechtigung für diese Seite.", "You are not authorized to view this page.", "U bent niet gemachtigd om deze pagina te bekijken.")</p>
                    }
                </NotAuthorized>
                <Authorizing>
                    <p>@L.T("Laden...", "Loading...", "Laden...")</p>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">@L.T("Diese Adresse existiert nicht.", "Sorry, there's nothing at this address.", "Sorry, er is niets op dit adres.")</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    protected override void OnInitialized()
    {
        L.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnChange -= HandleLanguageChanged;
    }
}
