@inherits LayoutComponentBase
@inject Gambling5.Web.Services.LanguageService L
@implements IDisposable
<div class="app-container">
    <NavMenu />
    
    <main class="main-content">
        <div @key="L.Current">
            @Body
        </div>
    </main>
    
    <footer class="site-footer">
        <div class="container">
            <p>&copy; 2026 G♠mblinG5. @L.T("Ich wette, es gefällt Ihnen.", "I bet you'll like it.", "Ik wed dat je het leuk vindt.")</p>
            <p>Version @SiteVersion</p>
        </div>
    </footer>
</div>

@code {
    private static readonly string SiteVersion =
        typeof(Program).Assembly.GetName().Version?.ToString(3) ?? "unknown";

    protected override void OnInitialized()
    {
        L.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnChange -= HandleLanguageChanged;
    }
}
