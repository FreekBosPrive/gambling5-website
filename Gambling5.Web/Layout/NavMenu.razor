<nav class="top-nav">
    <div class="nav-container">
        <a class="nav-brand" href="">
            <span class="nav-brand-text">G♠mblinG<span class="brand-five">5</span></span>
        </a>

        <div class="language-switcher" aria-label="Language switcher">
            <button type="button" class="lang-btn @(L.Current == "de" ? "active" : "")" @onclick='() => SetLanguage("de")'>DE</button>
            <button type="button" class="lang-btn @(L.Current == "en" ? "active" : "")" @onclick='() => SetLanguage("en")'>EN</button>
            <button type="button" class="lang-btn @(L.Current == "nl" ? "active" : "")" @onclick='() => SetLanguage("nl")'>NL</button>
        </div>
        
        <button class="nav-toggle" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
            <span class="nav-toggle-icon"></span>
            <span class="nav-toggle-icon"></span>
            <span class="nav-toggle-icon"></span>
        </button>
        
        <!-- Playing Card Navigation - Top Right -->
        <div class="card-nav">
            <NavLink class="nav-card spade" href="" Match="NavLinkMatch.All">
                <span class="suit">♠</span>
                <span class="label">Home</span>
            </NavLink>
            <NavLink class="nav-card heart" href="about">
                <span class="suit">♥</span>
                <span class="label">About</span>
            </NavLink>
            <NavLink class="nav-card diamond" href="gigs">
                <span class="suit">♦</span>
                <span class="label">Gigs</span>
            </NavLink>
            <NavLink class="nav-card club" href="contact">
                <span class="suit">♣</span>
                <span class="label">Contact</span>
            </NavLink>
        </div>
        
        <!-- Mobile fallback links -->
        <div class="nav-links-mobile @NavMenuCssClass">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CollapseNavMenu">
                Home
            </NavLink>
            <NavLink class="nav-link" href="about" @onclick="CollapseNavMenu">
                About
            </NavLink>
            <NavLink class="nav-link" href="gigs" @onclick="CollapseNavMenu">
                Gigs
            </NavLink>
            <NavLink class="nav-link" href="contact" @onclick="CollapseNavMenu">
                Book Us
            </NavLink>
        </div>
    </div>
</nav>

@code {
    [Inject] private Gambling5.Web.Services.LanguageService L { get; set; } = default!;

    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapsed" : null;
    
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
    
    private void CollapseNavMenu()
    {
        collapseNavMenu = true;
    }

    private void SetLanguage(string language)
    {
        L.SetLanguage(language);
    }
}
