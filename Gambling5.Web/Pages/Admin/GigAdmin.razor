@page "/admin/gigs"
@attribute [Authorize]
@using Gambling5.Web.Models
@using Gambling5.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject GigService GigService
@inject IConfiguration Configuration
@inject HttpClient Http
@inject IAccessTokenProvider TokenProvider
@inject Gambling5.Web.Services.LanguageService L

<PageTitle>@L.T("Gig Verwaltung", "Gig Management", "Gigbeheer") - G♠mblinG5</PageTitle>

<div class="page-background page-bg-gigs">

<div class="page-header">
    <h1 class="page-title">@L.T("Gig Verwaltung", "Gig Management", "Gigbeheer")</h1>
</div>

<div class="parchment-card">
    <AuthorizeView>
        <Authorized Context="authContext">
            <p class="admin-welcome">@L.T("Willkommen", "Welcome", "Welkom"), @authContext.User.Identity?.Name</p>
            
            <section class="admin-section">
                <h2 class="section-title">@(editingGig == null ? L.T("Neuer Gig", "New Gig", "Nieuwe Gig") : L.T("Gig bearbeiten", "Edit Gig", "Gig bewerken"))</h2>
                
                <EditForm Model="@currentGig" OnValidSubmit="SaveGig" class="gig-form">
                    <div class="form-group">
                        <label for="title">@L.T("Titel", "Title", "Titel")</label>
                        <InputText id="title" @bind-Value="currentGig.Title" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label for="date">@L.T("Datum", "Date", "Datum")</label>
                        <InputDate id="date" @bind-Value="currentGig.Date" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label for="venue">@L.T("Veranstaltungsort", "Venue", "Locatie")</label>
                        <InputText id="venue" @bind-Value="currentGig.Venue" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label for="status">@L.T("Status", "Status", "Status")</label>
                        <InputSelect id="status" @bind-Value="currentGig.Status" class="form-control">
                            <option value="confirmed">@L.T("Bestätigt", "Confirmed", "Bevestigd")</option>
                            <option value="public">@L.T("Öffentlich", "Public", "Openbaar")</option>
                            <option value="tentative">@L.T("Vorläufig", "Tentative", "Voorlopig")</option>
                            <option value="cancelled">@L.T("Abgesagt", "Cancelled", "Geannuleerd")</option>
                        </InputSelect>
                    </div>
                    
                    <div class="form-group">
                        <label>
                            <InputCheckbox @bind-Value="currentGig.IsPublic" />
                            @L.T("Öffentlich sichtbar", "Visible publicly", "Publiek zichtbaar")
                        </label>
                    </div>
                    
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? L.T("Speichern...", "Saving...", "Opslaan...") : (editingGig == null ? L.T("Hinzufügen", "Add", "Toevoegen") : L.T("Aktualisieren", "Update", "Bijwerken")))
                        </button>
                        @if (editingGig != null)
                        {
                            <button type="button" class="btn btn-secondary" @onclick="CancelEdit">@L.T("Abbrechen", "Cancel", "Annuleren")</button>
                        }
                    </div>
                </EditForm>
                
                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert @(isError ? "alert-error" : "alert-success")">@message</div>
                }
            </section>
            
            <section class="admin-section">
                <h2 class="section-title">@L.T("Alle Gigs", "All Gigs", "Alle Gigs")</h2>
                
                @if (isLoading)
                {
                    <p>@L.T("Lade Gigs...", "Loading gigs...", "Gigs laden...")</p>
                }
                else if (gigs == null || !gigs.Any())
                {
                    <p>@L.T("Keine Gigs vorhanden.", "No gigs available.", "Geen gigs beschikbaar.")</p>
                }
                else
                {
                    <div class="gigs-admin-list">
                        @foreach (var gig in gigs.OrderBy(g => g.Date))
                        {
                            <div class="gig-admin-card @(gig.IsPublic ? "" : "gig-hidden")">
                                <div class="gig-admin-info">
                                    <strong>@gig.Title</strong>
                                    <span class="gig-admin-date">@gig.Date.ToString("dd.MM.yyyy")</span>
                                    <span class="gig-admin-venue">@gig.Venue</span>
                                    <span class="gig-admin-status">@gig.Status @(gig.IsPublic ? "" : L.T("(versteckt)", "(hidden)", "(verborgen)"))</span>
                                </div>
                                <div class="gig-admin-actions">
                                    <button class="btn-icon" @onclick="() => EditGig(gig)" title='@L.T("Bearbeiten", "Edit", "Bewerken")'>✏️</button>
                                    <button class="btn-icon btn-danger" @onclick="() => DeleteGig(gig)" title='@L.T("Löschen", "Delete", "Verwijderen")'>🗑️</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
            
            <div class="admin-footer">
                <a href="/gigs" class="btn btn-secondary">← @L.T("Zurück zur Gig-Seite", "Back to gigs page", "Terug naar gigs-pagina")</a>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

</div>

@code {
    private List<Gig>? gigs;
    private Gig currentGig = new() { Date = DateTime.Today.AddMonths(1), Status = "confirmed", IsPublic = true };
    private Gig? editingGig;
    private bool isLoading = true;
    private bool isSaving = false;
    private string message = "";
    private bool isError = false;
    private string apiBaseUrl = "";

    protected override async Task OnInitializedAsync()
    {
        apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://gambling5-api.azurewebsites.net/api";
        await LoadGigs();
    }

    private async Task LoadGigs()
    {
        isLoading = true;
        try
        {
            gigs = await Http.GetFromJsonAsync<List<Gig>>($"{apiBaseUrl}/gigs");
        }
        catch (Exception ex)
        {
            message = $"{L.T("Fehler beim Laden", "Error while loading", "Fout bij laden")}: {ex.Message}";
            isError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void EditGig(Gig gig)
    {
        editingGig = gig;
        currentGig = new Gig
        {
            Id = gig.Id,
            Title = gig.Title,
            Date = gig.Date,
            Venue = gig.Venue,
            Status = gig.Status,
            Description = gig.Description,
            IsPublic = gig.IsPublic
        };
    }

    private void CancelEdit()
    {
        editingGig = null;
        currentGig = new Gig { Date = DateTime.Today.AddMonths(1), Status = "confirmed", IsPublic = true };
        message = "";
    }

    private async Task<HttpRequestMessage> CreateAdminRequestAsync(HttpMethod method, string url, object? content = null)
    {
        var apiScope = Configuration["AzureAd:ApiScope"];
        if (string.IsNullOrWhiteSpace(apiScope))
        {
            var clientId = Configuration["AzureAd:ClientId"];
            if (!string.IsNullOrWhiteSpace(clientId))
            {
                apiScope = $"api://{clientId}/access_as_user";
            }
        }

        if (string.IsNullOrWhiteSpace(apiScope))
        {
            throw new InvalidOperationException(L.T("Azure AD API-Scope ist nicht konfiguriert.", "Azure AD API scope is not configured.", "Azure AD API-scope is niet geconfigureerd."));
        }

        var tokenResult = await TokenProvider.RequestAccessToken(new AccessTokenRequestOptions
        {
            Scopes = [apiScope]
        });

        if (!tokenResult.TryGetToken(out var token))
        {
            throw new InvalidOperationException(L.T("Azure AD Zugriffstoken für die Admin-API konnte nicht abgerufen werden.", "Could not acquire an Azure AD access token for the admin API.", "Kon geen Azure AD toegangstoken voor de admin-API ophalen."));
        }

        var request = new HttpRequestMessage(method, url);
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token.Value);

        if (content is not null)
        {
            request.Content = JsonContent.Create(content);
        }

        return request;
    }

    private async Task SaveGig()
    {
        isSaving = true;
        message = "";
        
        try
        {
            var request = await CreateAdminRequestAsync(HttpMethod.Post, $"{apiBaseUrl}/gigs", currentGig);
            
            var response = await Http.SendAsync(request);
            
            if (response.IsSuccessStatusCode)
            {
                message = editingGig == null ? L.T("Gig erfolgreich hinzugefügt!", "Gig added successfully!", "Gig succesvol toegevoegd!") : L.T("Gig erfolgreich aktualisiert!", "Gig updated successfully!", "Gig succesvol bijgewerkt!");
                isError = false;
                CancelEdit();
                await LoadGigs();
            }
            else
            {
                message = $"{L.T("Fehler", "Error", "Fout")}: {response.StatusCode}";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"{L.T("Fehler", "Error", "Fout")}: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteGig(Gig gig)
    {
        try
        {
            var request = await CreateAdminRequestAsync(HttpMethod.Delete, $"{apiBaseUrl}/gigs/{gig.Id}");
            var response = await Http.SendAsync(request);
            
            if (response.IsSuccessStatusCode)
            {
                message = L.T("Gig gelöscht!", "Gig deleted!", "Gig verwijderd!");
                isError = false;
                await LoadGigs();
            }
            else
            {
                message = $"{L.T("Fehler beim Löschen", "Error while deleting", "Fout bij verwijderen")}: {response.StatusCode}";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"{L.T("Fehler", "Error", "Fout")}: {ex.Message}";
            isError = true;
        }
    }
}
