@page "/contact"
@using System.Net.Http.Json
@inject IConfiguration Configuration
@inject HttpClient Http
@inject Gambling5.Web.Services.LanguageService L

<PageTitle>@L.T("Kontakt", "Contact", "Contact") - G♠mblinG5</PageTitle>

<div class="page-background page-bg-contact">

    <div class="page-header">
        <h1 class="page-title">@L.T("Kontakt", "Contact", "Contact")</h1>
    </div>

    <div class="parchment-card">
        <section class="intro-section">
            <div class="contact-box">
                <h2 class="contact-title">@L.T("Kontakt:", "Contact:", "Contact:")</h2>
                <p class="contact-name">Florian Tschamler</p>
                <p class="contact-info">@L.T("Telefon", "Phone", "Telefoon"): 08179/5405</p>
                <p class="contact-info">@L.T("Mobil", "Mobile", "Mobiel"): 0176/18853226</p>
                <p class="contact-info">E-Mail: <a href="mailto:info@gambling5.de"
                        class="contact-email">info@gambling5.de</a></p>
            </div>
        </section>

        <section class="content-section">
            <h2 class="section-title">@L.T("Anfrage senden", "Send Request", "Aanvraag versturen")</h2>
            <p class="intro-text text-center mb-2">@L.T("Füllen Sie das Formular aus und wir melden uns innerhalb von 24 Stunden.", "Fill out the form and we will get back to you within 24 hours.", "Vul het formulier in en we reageren binnen 24 uur.")</p>

            @if (messageSent)
            {
                <div class="alert alert-success">
                    <strong>@L.T("Vielen Dank!", "Thank you!", "Dank je wel!")</strong> @L.T("Ihre Nachricht wurde gesendet. Wir melden uns bald bei Ihnen!", "Your message has been sent. We will get back to you soon!", "Je bericht is verzonden. We nemen snel contact met je op!")
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }
                <form class="contact-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    <div class="form-group">
                        <label class="form-label" for="name">@L.T("Name", "Name", "Naam") *</label>
                        <input type="text" id="name" class="form-control" @bind="name" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="email">E-Mail *</label>
                        <input type="email" id="email" class="form-control" @bind="email" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="phone">@L.T("Telefon", "Phone", "Telefoon")</label>
                        <input type="tel" id="phone" class="form-control" @bind="phone" />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="eventType">@L.T("Art der Veranstaltung", "Type of Event", "Type Evenement")</label>
                        <select id="eventType" class="form-control" @bind="eventType">
                            <option value="">@L.T("Bitte wählen...", "Please choose...", "Maak een keuze...")</option>
                            <option value="firmenfeier">@L.T("Firmenfeier", "Corporate Event", "Bedrijfsevent")</option>
                            <option value="privatfest">@L.T("Privatfest", "Private Party", "Privéfeest")</option>
                            <option value="kneipe">@L.T("Kneipenabend", "Pub Night", "Café-avond")</option>
                            <option value="festival">@L.T("Festival/Öffentlich", "Festival/Public", "Festival/Openbaar")</option>
                            <option value="sonstiges">@L.T("Sonstiges", "Other", "Overig")</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="date">@L.T("Datum der Veranstaltung", "Event Date", "Datum van het evenement")</label>
                        <input type="text" id="date" class="form-control" @bind="eventDate"
                            placeholder='@L.T("z.B. 15. März 2026", "e.g. March 15, 2026", "bijv. 15 maart 2026")' />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="message">@L.T("Nachricht", "Message", "Bericht") *</label>
                        <textarea id="message" class="form-control" rows="5" @bind="message" required></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-large" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span>@L.T("Wird gesendet...", "Sending...", "Wordt verzonden...")</span>
                            }
                            else
                            {
                                <span>@L.T("Nachricht senden", "Send Message", "Bericht verzenden")</span>
                            }
                        </button>
                    </div>
                </form>
            }
        </section>
    </div>

</div>

@code {
    private string name = "";
    private string email = "";
    private string phone = "";
    private string eventType = "";
    private string eventDate = "";
    private string message = "";
    private bool isSubmitting = false;
    private bool messageSent = false;
    private string errorMessage = "";

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://gambling5-api.azurewebsites.net/api";

            var request = new HttpRequestMessage(HttpMethod.Post, $"{apiBaseUrl}/contact");
            request.Content = JsonContent.Create(new
            {
                name,
                email,
                phone,
                eventType,
                eventDate,
                message
            });

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                messageSent = true;
            }
            else
            {
                errorMessage = L.T("Es gab einen Fehler beim Senden. Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per E-Mail.", "There was an error while sending. Please try again or contact us directly by email.", "Er is een fout opgetreden bij het verzenden. Probeer het opnieuw of neem direct contact op via e-mail.");
            }
        }
        catch (Exception)
        {
            errorMessage = L.T("Es gab einen Fehler beim Senden. Bitte versuchen Sie es erneut oder kontaktieren Sie uns direkt per E-Mail.", "There was an error while sending. Please try again or contact us directly by email.", "Er is een fout opgetreden bij het verzenden. Probeer het opnieuw of neem direct contact op via e-mail.");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
