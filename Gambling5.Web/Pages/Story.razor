@page "/story"
@inject Gambling5.Web.Services.LanguageService L

<PageTitle>@L.T("Geschichte", "Story", "Verhaal") - G♠mblinG5</PageTitle>

<div class="page-background page-bg-about">

    <div class="page-header">
        <h1 class="page-title">@L.T("Geschichte", "Story", "Verhaal")</h1>
    </div>

    <div class="parchment-card">
        <section class="intro-section">
            <h2 class="section-title">@L.T("Die Überraschung hinter Gambling 5", "The surprise behind Gambling 5", "De verrassing achter Gambling 5")</h2>
            <p class="intro-text">
                @L.T(
                    "Gambling 5 steht für fünf Musiker, handgemachte Energie und Songs, die man kennt, aber nicht an jeder Ecke hört.",
                    "Gambling 5 stands for five musicians, handmade energy, and songs people know without hearing them everywhere.",
                    "Gambling 5 staat voor vijf muzikanten, handgemaakte energie en nummers die je kent, maar niet overal hoort.")
            </p>
            <p class="intro-text">
                @L.T(
                    "Unsere Geschichte beginnt dort, wo ein guter Abend beginnt: mit Spielfreude, überraschenden Klassikern und dem Wunsch, das Publikum mitzunehmen.",
                    "Our story starts where a good night starts: with joy, surprising classics, and the urge to bring the audience along.",
                    "Ons verhaal begint waar een goede avond begint: met speelplezier, verrassende klassiekers en de wil om het publiek mee te nemen.")
            </p>
        </section>

        <section class="surprise-section">
            <h3 class="surprise-title">@L.T("Nicht gewöhnlich. Genau deshalb.", "Not ordinary. Exactly why.", "Niet gewoon. Precies daarom.")</h3>
            <p class="surprise-text">
                @L.T(
                    "Von akustisch bis elektrisch, von Rock bis Pop: Wir suchen die Stücke, die Charakter haben und live wirklich zünden.",
                    "From acoustic to electric, from rock to pop: we look for songs with character that truly come alive on stage.",
                    "Van akoestisch tot elektrisch, van rock tot pop: wij zoeken nummers met karakter die live echt tot leven komen.")
            </p>
        </section>
    </div>

</div>
