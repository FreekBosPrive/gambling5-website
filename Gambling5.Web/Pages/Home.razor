@page "/"

<PageTitle>Home - G♠mblinG5</PageTitle>

<div class="page-background page-bg-home">

<section class="hero-section">
    <div class="hero-content">
        <div class="hero-logo-wrapper">
            <div class="logo-spotlight"></div>
            <img src="images/logo.png" alt="G♠mblinG5 Logo" class="hero-logo" />
        </div>
        <p class="hero-tagline">I bet you'll like it!</p>
        <div class="hero-actions">
            <a href="gigs" class="btn btn-primary">View Shows</a>
            <a href="contact" class="btn btn-secondary">Book Us</a>
        </div>
    </div>
</section>

<div class="parchment-card">
    <section class="intro-section">
        <h2 class="section-title">Wir sind Gambling 5.</h2>
        <p class="intro-text">
            Wir sind 5 Musiker aus Beuerberg und Huglfing mit über 30 Jahren Bühnenpräsenz, Auftritte auf 
            kleinen und großen Festivals, Kleinkunstbühnen, Privatfesten, Apres Skipartys... wo wir unsere 
            besonderen „unknown" Rock- und Pop Klassiker zum Besten geben.
        </p>
        <p class="intro-text">
            <strong class="highlight-text">Das Besondere an Gambling 5 ist die Mischung der Stücke und Interpreten.</strong>
        </p>
        <p class="intro-text">
            Von Golden Earring über Tom Petty, Spandau Ballet bis Beyoncé.
        </p>
    </section>

    <section class="surprise-section">
        <h3 class="surprise-title">Die Überraschung:</h3>
        <p class="surprise-text">
            Rock und Pop Klassiker im akustisch-elektrischen Stil die selten oder nie im Radio laufen, 
            aber trotzdem jeder schon mal gehört hat und es einfach nur geil findet.
        </p>
        <p class="surprise-text">
            Von den 70ern begonnen bis in die 2000er. Kein abgedroschener Mainstream Rock-Pop sondern 
            einfach mal was anderes. <strong>Anhörbar, Tanzbar, Mitreissend.</strong>
        </p>
    </section>

    <section class="repertoire-section">
        <h2 class="section-title">Unser Repertoire</h2>
        <div class="repertoire-grid">
            <div class="repertoire-card">
                <div class="repertoire-icon">♠</div>
                <h3 class="repertoire-title">Rock</h3>
                <p class="repertoire-desc">Zeitlose Klassiker die mitreißen</p>
            </div>
            <div class="repertoire-card">
                <div class="repertoire-icon">♥</div>
                <h3 class="repertoire-title">Pop</h3>
                <p class="repertoire-desc">Hits zum Mitsingen aus jeder Dekade</p>
            </div>
            <div class="repertoire-card">
                <div class="repertoire-icon">♣</div>
                <h3 class="repertoire-title">Soul & Funk</h3>
                <p class="repertoire-desc">Grooves die die Tanzfläche füllen</p>
            </div>
            <div class="repertoire-card">
                <div class="repertoire-icon">♦</div>
                <h3 class="repertoire-title">Akustisch und Elektrisch</h3>
                <p class="repertoire-desc">"Überraschend für jede Gelegenheit"</p>
            </div>
        </div>
    </section>

    <section class="members-section">
        <h2 class="members-title">Die internationalen Musiker:</h2>
        <div class="member-item">
            <span class="member-origin">TÖL:</span>
            <span class="member-name">Florian Tschamler:</span>
            <span class="member-instruments">Bass, Vocals</span>
        </div>
        <div class="member-item">
            <span class="member-origin">TÖL:</span>
            <span class="member-name">Linus Winkler:</span>
            <span class="member-instruments">Gitarre, Vocals</span>
        </div>
        <div class="member-item">
            <span class="member-origin">WM:</span>
            <span class="member-name">Boris Alexander Klöck:</span>
            <span class="member-instruments">Drums, Percussion</span>
        </div>
        <div class="member-item">
            <span class="member-origin">NL:</span>
            <span class="member-name">Ingrid Verhagen:</span>
            <span class="member-instruments">Vocals, Piano, Akkordeon, Bluesharp</span>
        </div>
        <div class="member-item">
            <span class="member-origin">NL:</span>
            <span class="member-name">Freek Bos:</span>
            <span class="member-instruments">Vocals, Leadgitarre</span>
        </div>
    </section>
</div>

<section class="cta-section">
    <div class="cta-card">
        <h2 class="section-title">Bereit für Ihren Event?</h2>
        <p class="intro-text text-center mb-2">Kontaktieren Sie uns für Buchungen und Verfügbarkeit</p>
        <a href="contact" class="btn btn-primary btn-large">Jetzt Anfragen</a>
    </div>
</section>

</div>
