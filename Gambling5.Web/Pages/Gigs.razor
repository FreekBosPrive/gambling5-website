@page "/gigs"
@using Gambling5.Web.Models
@using Gambling5.Web.Services
@inject GigService GigService

<PageTitle>Auftritte - G♠mblinG5</PageTitle>

<div class="page-background page-bg-gigs">

<div class="page-header">
    <h1 class="page-title">Auftritte</h1>
</div>

<div class="parchment-card">
    <section class="intro-section">
        <h2 class="section-title">Kommende Shows</h2>
        <p class="intro-text text-center">Hier finden Sie unsere nächsten Auftritte. Kommen Sie vorbei!</p>
    </section>

    <div class="gigs-list">
        @if (isLoading)
        {
            <div class="loading-message">
                <p>Lade Auftritte...</p>
            </div>
        }
        else if (gigs == null || !gigs.Any())
        {
            <div class="no-gigs-message">
                <p>Keine kommenden Auftritte geplant. Schauen Sie bald wieder vorbei!</p>
            </div>
        }
        else
        {
            @foreach (var gig in gigs)
            {
                <div class="gig-card">
                    <div class="gig-date">
                        <span class="gig-month">@gig.Date.ToString("MMM", new System.Globalization.CultureInfo("de-DE")).ToUpper()</span>
                        <span class="gig-day">@gig.Date.Day</span>
                        <span class="gig-year">@gig.Date.Year</span>
                    </div>
                    <div class="gig-details">
                        <h3>@gig.Title</h3>
                        <p class="gig-venue">@gig.Venue</p>
                    </div>
                    <span class="gig-status @GetStatusClass(gig.Status)">@GetStatusText(gig.Status)</span>
                </div>
            }
        }
    </div>

    <section class="content-section text-center">
        <h3 class="surprise-title">Live Musik gesucht?</h3>
        <p class="intro-text">
            Wir nehmen immer gerne Buchungen entgegen! Ob Firmenfeier, Privatfest, 
            Hochzeit oder öffentliche Veranstaltung – wir bringen die Unterhaltung.
        </p>
        <a href="/contact" class="btn btn-primary">Verfügbarkeit prüfen</a>
    </section>
    
    <div class="admin-link-container">
        <a href="/admin/gigs" class="admin-link">•</a>
    </div>
</div>

</div>

@code {
    private List<Gig>? gigs;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            gigs = await GigService.GetUpcomingGigsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "confirmed" => "status-confirmed",
        "public" => "status-public",
        "tentative" => "status-tentative",
        "cancelled" => "status-cancelled",
        _ => "status-confirmed"
    };

    private string GetStatusText(string status) => status.ToLower() switch
    {
        "confirmed" => "Bestätigt",
        "public" => "Öffentlich",
        "tentative" => "Vorläufig",
        "cancelled" => "Abgesagt",
        _ => "Bestätigt"
    };
}
