@page "/gigs"
@using Gambling5.Web.Models
@using Gambling5.Web.Services
@inject GigService GigService
@inject LanguageService L

<PageTitle>@L.T("Auftritte", "Gigs", "Optredens") - G♠mblinG5</PageTitle>

<div class="page-background page-bg-gigs">

    <div class="page-header">
        <h1 class="page-title">@L.T("Auftritte", "Gigs", "Optredens")</h1>
    </div>

    <div class="parchment-card">
        <section class="intro-section">
            <h2 class="section-title">@L.T("Kommende Shows", "Upcoming Shows", "Komende Shows")</h2>
            <p class="intro-text text-center">@L.T("Hier finden Sie unsere nächsten Auftritte. Kommen Sie vorbei!", "Here you can find our next shows. Come by!", "Hier vind je onze volgende optredens. Kom langs!")</p>
        </section>

        <div class="gigs-list">
            @if (isLoading)
            {
                <div class="loading-message">
                    <p>@L.T("Lade Auftritte...", "Loading gigs...", "Optredens laden...")</p>
                </div>
            }
            else if (gigs == null || !gigs.Any())
            {
                <div class="no-gigs-message">
                    <p>@L.T("Keine kommenden Auftritte geplant. Schauen Sie bald wieder vorbei!", "No upcoming gigs scheduled. Check back soon!", "Geen komende optredens gepland. Kom snel terug!")</p>
                </div>
            }
            else
            {
                @foreach (var gig in gigs)
                {
                    <div class="gig-card">
                        <div class="gig-date">
                            <span class="gig-month">@gig.Date.ToString("MMM", new
                                                        System.Globalization.CultureInfo("de-DE")).ToUpper()</span>
                    <span class="gig-day">@gig.Date.Day</span>
                    <span class="gig-year">@gig.Date.Year</span>
                </div>
                <div class="gig-details">
                    <h3>@gig.Title</h3>
                    <p class="gig-venue">@gig.Venue</p>
                </div>
                <span class="gig-status @GetStatusClass(gig.Status)">@GetStatusText(gig.Status)</span>
            </div>
                        }
            }
        </div>

        <section class="content-section text-center">
            <h3 class="surprise-title">@L.T("Live-Musik mit Energie gesucht?", "Looking for high-energy live music?", "Op zoek naar energieke livemuziek?")</h3>
            <p class="intro-text">
                @L.T("Bucht Gambling 5 für euer Event – wir liefern Power, Stimmung und ein echtes Live-Erlebnis. Egal ob Firmenfeier, Privatparty, Kneipenabend oder Festival: Wir reißen euch mit!", "Book Gambling 5 for your event - we deliver power, atmosphere and a real live experience. Whether it's a corporate event, private party, pub night or festival: we get everyone moving!", "Boek Gambling 5 voor jullie event - wij brengen power, sfeer en een echte live-ervaring. Of het nu een bedrijfsevent, privéfeest, café-avond of festival is: wij slepen iedereen mee!")
            </p>
            <a href="/contact" class="btn btn-primary">@L.T("Verfügbarkeit prüfen", "Check Availability", "Beschikbaarheid checken")</a>
        </section>

        <div class="admin-link-container">
            <a href="/admin/gigs" class="admin-link">
                <img src="/images/dice.png" alt="" class="admin-dice" />
            </a>
        </div>
    </div>

</div>

@code {
    private List<Gig>? gigs;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            gigs = await GigService.GetUpcomingGigsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "confirmed" => "status-confirmed",
        "public" => "status-public",
        "tentative" => "status-tentative",
        "cancelled" => "status-cancelled",
        _ => "status-confirmed"
    };

    private string GetStatusText(string status) => status.ToLower() switch
    {
        "confirmed" => L.T("Bestätigt", "Confirmed", "Bevestigd"),
        "public" => L.T("Öffentlich", "Public", "Openbaar"),
        "tentative" => L.T("Vorläufig", "Tentative", "Voorlopig"),
        "cancelled" => L.T("Abgesagt", "Cancelled", "Geannuleerd"),
        _ => L.T("Bestätigt", "Confirmed", "Bevestigd")
    };
}