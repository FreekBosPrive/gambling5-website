@page "/about"
@inject Gambling5.Web.Services.LanguageService L

<PageTitle>@L.T("Über Uns", "About Us", "Over Ons") - G♠mblinG5</PageTitle>

<div class="page-background page-bg-about">

    <div class="page-header">
        <h1 class="page-title">@L.T("Über", "About", "Over") G♠mblinG<span class="brand-five">5</span></h1>
    </div>

    <div class="parchment-card">
        <section class="intro-section">
            <h2 class="section-title">@L.T("Wir sind Gambling 5.", "We are Gambling 5.", "Wij zijn Gambling 5.")</h2>
            <p class="intro-text">
                @L.T(
                    "Fünf Musiker, eine Mission: Energie, Power und echtes Live-Feeling! Wir bringen jede Bühne zum Beben – mit akustischer und elektrischer Wucht, Spielfreude und Leidenschaft. Unser Sound ist handgemacht, ehrlich und immer mitreißend.",
                    "Five musicians, one mission: energy, power and real live feeling! We shake every stage with acoustic and electric force, joy of playing and passion. Our sound is handcrafted, honest and always captivating.",
                    "Vijf muzikanten, een missie: energie, power en echt live-gevoel! Wij laten elk podium trillen met akoestische en elektrische kracht, speelplezier en passie. Onze sound is handgemaakt, eerlijk en altijd meeslepend.")
            </p>
        </section>

        <section class="surprise-section">
            <h3 class="surprise-title">@L.T("Das ist Gambling 5:", "This is Gambling 5:", "Dit is Gambling 5:")</h3>
            <p class="surprise-text">
                @L.T(
                    "Einzigartige Songauswahl, überraschende Klassiker, pure Spielfreude. Von Golden Earring über Tom Petty, Spandau Ballet bis Beyonce – wir spielen, was bewegt und begeistert.",
                    "Unique song selection, surprising classics, pure joy of performance. From Golden Earring and Tom Petty to Spandau Ballet and Beyonce - we play what moves and excites.",
                    "Unieke songkeuze, verrassende klassiekers, puur speelplezier. Van Golden Earring en Tom Petty tot Spandau Ballet en Beyonce - wij spelen wat raakt en enthousiast maakt.")
            </p>
            <p class="surprise-text">
                @L.T(
                    "Unsere Shows sind voller Energie, Interaktion und Leidenschaft. Kein Mainstream, sondern Songs mit Charakter – immer tanzbar, immer mitreißend, immer live.",
                    "Our shows are full of energy, interaction and passion. No mainstream, but songs with character - always danceable, always captivating, always live.",
                    "Onze shows zitten vol energie, interactie en passie. Geen mainstream, maar nummers met karakter - altijd dansbaar, altijd meeslepend, altijd live.")
            </p>
        </section>

        <section class="members-section">
            <h2 class="members-title">@L.T("Die internationalen Musiker:", "The international musicians:", "De internationale muzikanten:")</h2>
            <div class="member-item">
                <span class="member-origin">NL:</span>
                <span class="member-name">Ingrid Verhagen:</span>
                <span class="member-instruments">Vocals, Piano, Akkordeon, Bluesharp</span>
            </div>
            <div class="member-item">
                <span class="member-origin">NL:</span>
                <span class="member-name">Freek Bos:</span>
                <span class="member-instruments">Vocals, Leadgitarre</span>
            </div>
            <div class="member-item">
                <span class="member-origin">WM:</span>
                <span class="member-name">Boris Alexander Klöck:</span>
                <span class="member-instruments">Drums, Percussion</span>
            </div>
            <div class="member-item">
                <span class="member-origin">TÖL:</span>
                <span class="member-name">Linus Winkler:</span>
                <span class="member-instruments">@L.T("Luftgitarre, Stromgitarre, Vocals", "Air guitar, electric guitar, vocals", "Luchtgitaar, elektrische gitaar, vocals")</span>
            </div>
            <div class="member-item">
                <span class="member-origin">TÖL:</span>
                <span class="member-name">Florian Tschamler:</span>
                <span class="member-instruments">Bass, Vocals</span>
            </div>
        </section>

        <section class="content-section">
            <h2 class="section-title">@L.T("Perfekt Für", "Perfect For", "Perfect Voor")</h2>
            <div class="repertoire-grid">
                <div class="repertoire-card">
                    <div class="repertoire-icon">♠</div>
                    <h3 class="repertoire-title">@L.T("Firmenfeiern", "Corporate Events", "Bedrijfsevents")</h3>
                    <p class="repertoire-desc">@L.T("Events, bei denen Energie und Stimmung gefragt sind", "Events where energy and atmosphere matter", "Events waar energie en sfeer centraal staan")</p>
                </div>
                <div class="repertoire-card">
                    <div class="repertoire-icon">♥</div>
                    <h3 class="repertoire-title">@L.T("Privatfeste", "Private Parties", "Privéfeesten")</h3>
                    <p class="repertoire-desc">@L.T("Geburtstage, Jubiläen und Partys mit Live-Power", "Birthdays, anniversaries and parties with live power", "Verjaardagen, jubilea en feesten met live power")</p>
                </div>
                <div class="repertoire-card">
                    <div class="repertoire-icon">♣</div>
                    <h3 class="repertoire-title">@L.T("Kneipenabende", "Pub Nights", "Café-avonden")</h3>
                    <p class="repertoire-desc">@L.T("Mitreißende Live-Musik, die niemanden sitzen lässt", "Captivating live music that gets everyone moving", "Meeslepende livemuziek die niemand laat stilzitten")</p>
                </div>
                <div class="repertoire-card">
                    <div class="repertoire-icon">♦</div>
                    <h3 class="repertoire-title">Festivals</h3>
                    <p class="repertoire-desc">@L.T("Von kleinen Kneipen über größere Venues bis zu Privatveranstaltungen und Festivals", "From small pubs and larger venues to private events and festivals", "Van kleine cafés en grotere zalen tot privé-evenementen en festivals")</p>
                </div>
            </div>
        </section>
    </div>

    <section class="cta-section">
        <div class="cta-card">
            <h2 class="section-title">@L.T("Bereit für Ihren Event?", "Ready for your event?", "Klaar voor jouw event?")</h2>
            <p class="intro-text text-center mb-2">@L.T("Kontaktieren Sie uns für Buchungen und Verfügbarkeit", "Contact us for bookings and availability", "Neem contact met ons op voor boekingen en beschikbaarheid")</p>
            <a href="/contact" class="btn btn-primary btn-large">@L.T("Jetzt Anfragen", "Request Now", "Nu Aanvragen")</a>
        </div>
    </section>

</div>